# ApplyAgent Environment Configuration
# Copy to ~/.applyagent/.env and fill in your values.

# LLM Provider (pick one, or both for auto-fallback)
GEMINI_API_KEY=           # Gemini 2.0 Flash (recommended, free tier works)
# OPENAI_API_KEY=         # OpenAI (GPT-4o-mini)
# LLM_URL=http://localhost:11434/v1  # Local LLM (Ollama / llama.cpp)
# LLM_MODEL=              # Override model name (e.g. qwen2.5:14b)
#
# Tip: set BOTH a cloud key AND LLM_URL for automatic fallback.
# Gemini handles requests normally; if rate-limited, your local model
# takes over until Gemini recovers. No extra config needed.

# Auto-Apply agent model (optional, for --local mode)
# --local means "use Python Playwright instead of Claude Code CLI".
# The LLM itself does NOT have to be local — Gemini works great and is free.
#
# APPLY_LLM_MODEL=gemini-2.0-flash    # Recommended: free, capable (uses your GEMINI_API_KEY)
# APPLY_LLM_MODEL=qwen2.5:32b         # Or a large local model (8B is too small for agent tasks)
# APPLY_LLM_URL=http://localhost:11434/v1   # Dedicated apply endpoint (if different from LLM_URL)

# Auto-Apply (optional)
CAPSOLVER_API_KEY=        # For CAPTCHA solving during auto-apply

# Proxy (optional, for scraping)
# PROXY=host:port:user:pass
